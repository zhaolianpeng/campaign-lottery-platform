ADMIN_USER=admin
ADMIN_PASSWORD=change-me
CORS_ALLOW_ORIGIN=http://localhost:3000
STORAGE_MODE=memory

# MySQL
MYSQL_ENABLED=false
MYSQL_DSN=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=campaign_lottery_platform
MYSQL_USER=campaign_lottery_app
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECTION_LIMIT=10

# Redis
REDIS_ENABLED=false
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=10
REDIS_KEY_PREFIX=campaign:lottery:

# WeChat OAuth / JS-SDK (placeholders — replace in production)
WECHAT_QUICK_LOGIN_ENABLED=false
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_TOKEN=
WECHAT_REDIRECT_URI=

# SMS verification provider placeholder.
# Keep SMS_PROVIDER=mock in local/dev; production should configure a real provider
# such as aliyun or tencent and complete the adapter implementation.
SMS_PROVIDER=mock
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# Carrier one-click phone auth placeholder.
CARRIER_AUTH_PROVIDER=
CARRIER_AUTH_APP_ID=
CARRIER_AUTH_API_KEY=

# Payment module (disabled by default; set true + config file to enable)
PAYMENT_ENABLED=false
PAYMENT_CONFIG_PATH=config/payment.config.json

# Guest initial points (configurable; avoid fixed high values in production)
GUEST_INITIAL_POINTS=100
